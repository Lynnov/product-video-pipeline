##############################################################################
# Product Video Pipeline - 环境变量配置文件
##############################################################################
#
# 使用说明：
#
# 1. 复制此文件为 .env
#    cp .env.example .env
#
# 2. 将 your-api-key-here 替换为您的实际 API 密钥
#
# 3. .env 文件不会被提交到 Git（已在 .gitignore 中配置）
#
##############################################################################

##############################################################################
# .env 文件位置说明
##############################################################################
#
# 推荐将本文件放在 product-video-pipeline skill 根目录：
#
#   github/skills/product-video-pipeline/.env
#
# 当前 skill 主要是 Markdown 工作流；如果后续增加自动化脚本，脚本应优先读取
# skill 根目录下的 .env，然后再读取系统环境变量。
#
##############################################################################

##############################################################################
# 必需的 API 密钥
##############################################################################

# KFC V50 API 密钥
# 用于：调用 https://kfcv50.link/v1/images/generations KFC V50 三方 gpt-image-2 生图接口
# 获取后将占位符替换为真实密钥，通常形如 sk-xxx
KFCV50_API_KEY=your-gemini-api-key-here


##############################################################################
# 可选的 API 密钥（视频功能）
##############################################################################

# 可灵 AI Access Key
# 用于：调用可灵视频生成能力；如果不使用可灵，可以留空
KLING_ACCESS_KEY=your-kling-access-key-here


# 可灵 AI Secret Key
# 用于：配合 KLING_ACCESS_KEY 使用；如果不使用可灵，可以留空
KLING_SECRET_KEY=your-kling-secret-key-here

##############################################################################
# 配置示例
##############################################################################
#
# 仅使用 KFC V50 gpt-image-2 生图：
#   KFCV50_API_KEY=sk-...
#   RIGHT_CODES_API_KEY=
#   KLING_ACCESS_KEY=
#   KLING_SECRET_KEY=
#
# 使用 Right Codes Draw 生图：
#   RIGHT_CODES_API_KEY=sk-...
#
# 使用生图 + 可灵视频：
#   KFCV50_API_KEY=sk-...
#   RIGHT_CODES_API_KEY=sk-...
#   KLING_ACCESS_KEY=ak-...
#   KLING_SECRET_KEY=sk-...
#
##############################################################################

##############################################################################
# 安全提醒
##############################################################################
#
# 永远不要将 .env 文件提交到 Git 仓库。
# 永远不要在代码或 Markdown 文档中硬编码 API 密钥。
# 永远不要在公开场合分享你的 API 密钥。
# 如果密钥曾经发到聊天或提交历史里，立刻去服务商后台重置。
#
##############################################################################
